# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# CLAUDE_API_KEY: Optional API key for Claude (Anthropic) fallback.
CLAUDE_API_KEY="MY_CLAUDE_API_KEY"

# ARMORIQ_API_KEY: Optional API key for ArmorIQ Prompt Security scanning.
ARMORIQ_API_KEY="MY_ARMORIQ_API_KEY"

# OLLAMA_ENDPOINT: Optional endpoint for local or custom Ollama instances (e.g. http://127.0.0.1:11434).
OLLAMA_ENDPOINT="http://127.0.0.1:11434"

# OLLAMA_MODEL: Optional default model to use for local Ollama runs (e.g. gemma2).
OLLAMA_MODEL="gemma2"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
